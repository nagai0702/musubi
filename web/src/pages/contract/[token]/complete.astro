---
import { getByToken, updateContract } from '@/lib/contracts';
const { token } = Astro.params;
const found = token ? await getByToken(token) : null;
if (found?.contract.status === 'signed') {
  await updateContract(token!, { status: 'payment_done' });
}
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>お手続き完了 - 結び</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f8f9fa; color: #333; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .done { text-align: center; padding: 40px 24px; max-width: 480px; }
    .icon { font-size: 64px; margin-bottom: 16px; }
    h1 { font-size: 22px; font-weight: 600; margin-bottom: 12px; color: #059669; }
    p { font-size: 14px; color: #666; line-height: 1.8; }
    .company { margin-top: 32px; font-size: 13px; color: #999; }
  </style>
</head>
<body>
  <div class="done">
    <div class="icon">✅</div>
    <h1>お手続きありがとうございました</h1>
    <p>
      ご契約のお手続きが完了しました。<br>
      担当者より改めてご連絡いたしますので、<br>
      今しばらくお待ちください。
    </p>
    <p class="company">株式会社結び</p>
  </div>
</body>
</html>
